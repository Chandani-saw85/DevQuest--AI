# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=devquest-secret-key-2024

# AI Configuration
AI_MODEL_VERSION=2.1.0
PREDICTION_CONFIDENCE_THRESHOLD=0.7

# Database
DB_TYPE=sqlite
DB_PATH=./data/devquest_ai.db

# Performance
MAX_CODE_LENGTH=50000
CODE_COMPLEXITY_LIMIT=50

# API
JAVA_BACKEND_URL=http://localhost:8080/api
REACT_FRONTEND_URL=http://localhost:3000

# Features
ADVANCED_PLAGIARISM_DETECTION=True
CODE_CLONE_DETECTION=True
ADAPTIVE_DIFFICULTY=True
PREDICTIVE_ANALYTICS=True

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/ai_engine.log
